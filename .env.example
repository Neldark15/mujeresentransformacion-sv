# ============================================
# Variables de entorno - Mujeres en Transformación
# Copiar este archivo a `.env.local` (Vercel)
# o configurarlas en el panel de Vercel:
#   Project → Settings → Environment Variables
# ============================================

# ----- n1co (pasarela de pagos) -----
# Solicitar al equipo de n1co (clientId + clientSecret) en sandbox y producción
N1CO_CLIENT_ID=
N1CO_CLIENT_SECRET=

# URLs base
# Sandbox:    https://api-sandbox.n1co.shop
# Producción: (confirmar con n1co cuando aprueben la cuenta)
N1CO_BASE_URL=https://api-sandbox.n1co.shop

# URL para CheckoutLink (suele ser la misma que N1CO_BASE_URL)
N1CO_CHECKOUT_BASE_URL=https://api-sandbox.n1co.shop

# Secret para validar webhooks (si n1co lo proporciona)
N1CO_WEBHOOK_SECRET=

# ----- URL pública del sitio -----
# Producción: https://mujeresentransformacion.com
# Preview:    https://<tu-rama>.vercel.app
SITE_URL=http://localhost:3000

# ----- Email transaccional (Sprint 3 — opcional) -----
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=

# ----- Base de datos (Sprint 3 — opcional) -----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
